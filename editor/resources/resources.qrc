  <!-- Surface textures (CC0, Poly Haven) for the textured render mode: albedo +
       normal (nor_gl, PNG — lossless) + roughness maps. Aliased from the
       committed, re-encoded files; rows in ASSETS_LICENSES.md. -->
  <qresource prefix="/textures">
    <file alias="asphalt.jpg">../../assets/textures/asphalt/asphalt_02_diff_512.jpg</file>
