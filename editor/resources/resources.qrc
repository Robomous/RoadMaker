<!-- Icons are addressed as :/icons/<name>.svg regardless of which set they
     come from (lucide/tabler/material/custom subdirectories) — the alias
     flattens the path so Icons::get("name") stays source-agnostic.
     Every file listed here needs a row in ASSETS_LICENSES.md (CI-enforced). -->
<RCC>
  <qresource prefix="/icons">
    <file alias="box.svg">icons/lucide/box.svg</file>
    <file alias="circle-plus.svg">icons/lucide/circle-plus.svg</file>
    <file alias="git-merge.svg">icons/lucide/git-merge.svg</file>
    <file alias="file-output.svg">icons/lucide/file-output.svg</file>
    <file alias="file-plus.svg">icons/lucide/file-plus.svg</file>
    <file alias="folder-open.svg">icons/lucide/folder-open.svg</file>
    <file alias="info.svg">icons/lucide/info.svg</file>
    <file alias="magnet.svg">icons/lucide/magnet.svg</file>
    <file alias="mountain.svg">icons/lucide/mountain.svg</file>
    <file alias="mouse-pointer-2.svg">icons/lucide/mouse-pointer-2.svg</file>
    <file alias="move.svg">icons/lucide/move.svg</file>
    <file alias="octagon-x.svg">icons/lucide/octagon-x.svg</file>
    <file alias="redo-2.svg">icons/lucide/redo-2.svg</file>
    <file alias="rotate-ccw.svg">icons/lucide/rotate-ccw.svg</file>
    <file alias="save.svg">icons/lucide/save.svg</file>
    <file alias="scan.svg">icons/lucide/scan.svg</file>
    <file alias="scissors.svg">icons/lucide/scissors.svg</file>
    <file alias="trash-2.svg">icons/lucide/trash-2.svg</file>
    <file alias="triangle-alert.svg">icons/lucide/triangle-alert.svg</file>
    <file alias="undo-2.svg">icons/lucide/undo-2.svg</file>
    <file alias="waypoints.svg">icons/lucide/waypoints.svg</file>
    <file alias="clothoid-road.svg">icons/custom/clothoid-road.svg</file>
    <file alias="junction-connect.svg">icons/custom/junction-connect.svg</file>
    <file alias="lane-section.svg">icons/custom/lane-section.svg</file>
    <file alias="template-highway.svg">icons/custom/template-highway.svg</file>
    <file alias="template-rural.svg">icons/custom/template-rural.svg</file>
    <file alias="template-urban.svg">icons/custom/template-urban.svg</file>
  </qresource>
  <!-- Full-colour application icon (coral robot). Multi-size so QIcon picks a
       crisp raster for the window/taskbar at any scale; the macOS Dock uses the
       bundled .icns and Windows the .rc/.ico instead. -->
  <qresource prefix="/branding">
    <file alias="icon_16.png">branding/icon_16.png</file>
    <file alias="icon_24.png">branding/icon_24.png</file>
    <file alias="icon_32.png">branding/icon_32.png</file>
    <file alias="icon_48.png">branding/icon_48.png</file>
    <file alias="icon_64.png">branding/icon_64.png</file>
    <file alias="icon_128.png">branding/icon_128.png</file>
    <file alias="icon_256.png">branding/icon_256.png</file>
  </qresource>
</RCC>
