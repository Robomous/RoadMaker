    <file alias="thumbnails/streetlight_single.png">../../assets/library/thumbnails/streetlight_single.png</file>
    <file alias="thumbnails/streetlight_double.png">../../assets/library/thumbnails/streetlight_double.png</file>
    <file alias="thumbnails/building_low.png">../../assets/library/thumbnails/building_low.png</file>
    <file alias="thumbnails/building_mid.png">../../assets/library/thumbnails/building_mid.png</file>
    <file alias="thumbnails/building_tower.png">../../assets/library/thumbnails/building_tower.png</file>
    <file alias="thumbnails/marking_solid_white.png">../../assets/library/thumbnails/marking_solid_white.png</file>
    <file alias="thumbnails/marking_double_yellow.png">../../assets/library/thumbnails/marking_double_yellow.png</file>
    <file alias="thumbnails/marking_dashed_white.png">../../assets/library/thumbnails/marking_dashed_white.png</file>
