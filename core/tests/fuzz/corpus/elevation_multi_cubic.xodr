<?xml version="1.0" encoding="UTF-8"?>
<!-- RoadMaker seed: elevation profile with four cubic records at increasing
     s and non-zero c/d terms. Exercises the elevation record loop.
     Hand-authored for the RoadMaker project (MIT license). -->
<OpenDRIVE>
  <header revMajor="1" revMinor="8" name="elevation_multi_cubic" vendor="Robomous"/>
  <road name="Rolling" length="120.0" id="1" junction="-1">
    <planView>
      <geometry s="0.0" x="0.0" y="0.0" hdg="0.0" length="120.0">
        <line/>
      </geometry>
    </planView>
    <elevationProfile>
      <elevation s="0.0" a="0.0" b="0.02" c="0.0004" d="-0.000002"/>
      <elevation s="30.0" a="1.2" b="0.05" c="-0.0006" d="0.000003"/>
      <elevation s="70.0" a="2.4" b="-0.01" c="0.0002" d="0.0"/>
      <elevation s="100.0" a="1.0" b="-0.03" c="0.0" d="0.0"/>
    </elevationProfile>
    <lanes>
      <laneSection s="0.0">
        <center>
          <lane id="0" type="none" level="false"/>
        </center>
        <right>
          <lane id="-1" type="driving" level="false">
            <width sOffset="0.0" a="3.5" b="0.0" c="0.0" d="0.0"/>
          </lane>
        </right>
      </laneSection>
    </lanes>
  </road>
</OpenDRIVE>
