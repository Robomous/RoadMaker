<?xml version="1.0" encoding="UTF-8"?>
<OpenDRIVE>
  <header revMajor="1" revMinor="8" name="roadmaker" vendor="RoadMaker" />
  <road length="60" id="r0" junction="-1">
    <planView>
      <geometry s="0" x="0" y="0" hdg="0" length="60">
        <line />
      </geometry>
    </planView>
    <lanes>
      <laneSection s="0">
        <center>
          <lane id="0" type="none" level="false">
            <roadMark sOffset="0" type="broken" width="0.12" />
          </lane>
        </center>
        <right>
          <lane id="-1" type="driving" level="false">
            <width sOffset="0" a="3.5" b="0" c="0" d="0" />
            <roadMark sOffset="0" type="solid" width="0.12" />
          </lane>
        </right>
      </laneSection>
    </lanes>
  </road>
  <userData code="rm:terrain" value="/etc/passwd" />
  <userData code="rm:terrain" value="../../outside.asc" />
  <userData code="rm:terrain" value="" />
</OpenDRIVE>
