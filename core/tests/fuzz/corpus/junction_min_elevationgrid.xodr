<?xml version="1.0" encoding="UTF-8"?>
<!-- RoadMaker seed: minimal junction (one connecting road + laneLink) plus a
     junction <planView>/<elevationGrid> block (OpenDRIVE 1.8). Exercises the
     junction surface-export round-trip on read. Hand-authored (MIT). -->
<OpenDRIVE>
  <header revMajor="1" revMinor="8" name="junction_min_elevationgrid" vendor="Robomous"/>
  <road name="In" length="20.0" id="1" junction="-1">
    <link><successor elementType="junction" elementId="100"/></link>
    <planView>
      <geometry s="0.0" x="-20.0" y="0.0" hdg="0.0" length="20.0"><line/></geometry>
    </planView>
    <lanes>
      <laneSection s="0.0">
        <center><lane id="0" type="none" level="false"/></center>
        <right><lane id="-1" type="driving" level="false">
          <width sOffset="0.0" a="3.5" b="0.0" c="0.0" d="0.0"/>
        </lane></right>
      </laneSection>
    </lanes>
  </road>
  <road name="Out" length="20.0" id="2" junction="-1">
    <link><predecessor elementType="junction" elementId="100"/></link>
    <planView>
      <geometry s="0.0" x="0.0" y="0.0" hdg="0.0" length="20.0"><line/></geometry>
    </planView>
    <lanes>
      <laneSection s="0.0">
        <center><lane id="0" type="none" level="false"/></center>
        <right><lane id="-1" type="driving" level="false">
          <width sOffset="0.0" a="3.5" b="0.0" c="0.0" d="0.0"/>
        </lane></right>
      </laneSection>
    </lanes>
  </road>
  <road name="Conn" length="20.0" id="10" junction="100">
    <link>
      <predecessor elementType="road" elementId="1" contactPoint="end"/>
      <successor elementType="road" elementId="2" contactPoint="start"/>
    </link>
    <planView>
      <geometry s="0.0" x="-20.0" y="0.0" hdg="0.0" length="20.0"><line/></geometry>
    </planView>
    <lanes>
      <laneSection s="0.0">
        <center><lane id="0" type="none" level="false"/></center>
        <right><lane id="-1" type="driving" level="false">
          <width sOffset="0.0" a="3.5" b="0.0" c="0.0" d="0.0"/>
          <link><predecessor id="-1"/><successor id="-1"/></link>
        </lane></right>
      </laneSection>
    </lanes>
  </road>
  <junction id="100" name="Min">
    <connection id="0" incomingRoad="1" connectingRoad="10" contactPoint="start">
      <laneLink from="-1" to="-1"/>
    </connection>
    <planView>
      <geometry s="0" x="-2.0" y="-2.0" hdg="0" length="4.0"><line/></geometry>
    </planView>
    <elevationGrid sStart="0" gridSpacing="2">
      <elevation left="0 0" center="0" right="0 0"/>
      <elevation left="0 0" center="0" right="0 0"/>
      <elevation left="0 0" center="0" right="0 0"/>
    </elevationGrid>
  </junction>
</OpenDRIVE>
