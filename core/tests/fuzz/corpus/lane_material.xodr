<?xml version="1.0" encoding="UTF-8"?>
<!-- RoadMaker sample: lane <material> records (§11.8.2) incl. an unmodeled
     @attr and an unmodeled lane child, plus roadMark @material. Hand-authored
     for the RoadMaker project (MIT license). -->
<OpenDRIVE>
  <header revMajor="1" revMinor="8" name="lane_material" vendor="Robomous"/>
  <road name="Material Test" length="80.0" id="1" junction="-1">
    <planView>
      <geometry s="0.0" x="0.0" y="0.0" hdg="0.0" length="80.0">
        <line/>
      </geometry>
    </planView>
    <lanes>
      <laneSection s="0.0">
        <center>
          <lane id="0" type="none" level="false">
            <roadMark sOffset="0.0" type="broken" width="0.12"/>
          </lane>
        </center>
        <right>
          <lane id="-1" type="driving" level="false">
            <width sOffset="0.0" a="3.5" b="0.0" c="0.0" d="0.0"/>
            <roadMark sOffset="0.0" type="solid" width="0.12" material="rm:paint_white"/>
            <material sOffset="0.0" friction="0.85" roughness="0.012" surface="rm:asphalt" colorHint="dark"/>
            <material sOffset="40.0" friction="0.7" surface="rm:asphalt_worn"/>
            <height sOffset="0.0" inner="0.0" outer="0.0"/>
            <userData code="rm:demo" value="1"/>
          </lane>
        </right>
      </laneSection>
    </lanes>
  </road>
</OpenDRIVE>
